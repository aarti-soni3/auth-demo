# --- Environment & Secrets ---
# Never commit actual credentials!
.env
.env.local
.env.*.local
*.pem
*.key
auth.json

# --- Dependencies ---
# Node.js
node_modules/
# Python
venv/
env/
__pycache__/
*.py[cod]
# Java/Maven/Gradle
.gradle/
build/
target/
# PHP/Composer
vendor/

# --- Database ---
# Local database files & dumps
*.sqlite
*.db
dump.rdb
/data/*.sql

# --- Build & Output ---
dist/
out/
bin/
*.exe
*.dll
*.so

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*

# --- Docker ---
.dockerignore
# Do not ignore Dockerfile or docker-compose.yml unless they contain secrets

# --- OS & IDE ---
.DS_Store
.vscode/
!.vscode/launch.json
.idea/
*.swp
